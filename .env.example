# Local dev — set to true to skip the MSAL login gate
NEXT_PUBLIC_SKIP_AUTH=false

# Entra ID
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
NEXT_PUBLIC_AZURE_AD_AUTHORITY=
NEXT_PUBLIC_AZURE_AD_REDIRECT_URI=

# API Keys (stored in Azure Key Vault in prod)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Fabric integration (for business context queries via Service Principal)
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=
FABRIC_WORKSPACE_ID=
FABRIC_DATASET_ID=
FABRIC_DATASET_NAME="amika POS Sales"

